#!/bin/bash

export XDG_CURRENT_DESKTOP=GNOME
export XDG_SESSION_DESKTOP=GNOME
export XDG_SESSION_TYPE=x11

# Export the session environment to the systemd user manager and D-Bus so that
# on-demand user services (notably xdg-desktop-portal) inherit DISPLAY etc.
systemctl --user import-environment DISPLAY XAUTHORITY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE
dbus-update-activation-environment --systemd DISPLAY XAUTHORITY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE

# Bring up graphical-session.target for this session.
#
# graphical-session.target has RefuseManualStart=yes, so it can only be pulled
# up as a dependency: bspwm-session.target BindsTo it, and starting that target
# activates it. This matters because xdg-desktop-portal >= 1.22 declares
# Requisite=graphical-session.target and refuses to start unless the target is
# active. Without it the portal is dead, which (among other things) breaks
# GTK/libadwaita dark mode -- apps read the color-scheme preference from the
# portal's org.freedesktop.portal.Settings interface.
#
# (Older portal versions, e.g. 1.20, had no such Requisite and D-Bus-activated
# on demand, so this was not needed there.)
systemctl --user start bspwm-session.target

# Start bspwm as the window manager.
exec bspwm
